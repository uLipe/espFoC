menu "espFoC Settings"

    config NOOF_AXIS
        int "Number of motor outputs"
        range 1 4
        default 1
        help
            The number of motor outputs available, this option
            is the number of motor sets, each set is composed
            by total PWM outputs and sensor inputs.

    config FOC_TASK_STACK_SIZE
        int "Task stack size of foc controller"
        default 3072

    config ESP_FOC_CUSTOM_MATH
        bool "Use custom espFoC fast math"
        default y

    config ESP_FOC_SCOPE
        bool "Enable scope data sending"
        default n

    config ESP_FOC_SCOPE_NUM_CHANNELS
        int "Maximum allowed channels"
        default 8

    config ESP_FOC_SCOPE_BUFFER_SIZE
        int "Size of scope buffer in frames"
        default 4096 if ESP_FOC_SCOPE_NUM_CHANNELS = 8
        default 1024

    choice
        prompt "Select espFoC modulation type"
        default ESP_FOC_USE_SPACE_VECTOR_PWM

    config ESP_FOC_USE_SINE_PWM
        bool "Use Sinewave modulation for PWM"

    config ESP_FOC_USE_SPACE_VECTOR_PWM
        bool "Use Sinewave modulation for PWM"

    endchoice

    config ESP_FOC_ENABLE_PCNT_DRIVER
        bool "Enable the PNCT driver"
        default n

    config ESP_FOC_DEBUG_CORE_TIMING
        bool "output on a pin the time taken to compute espfoc core ops"
        default n

    config ESP_FOC_DEBUG_PIN
        int "GPIO number of the debug pin"
        depends on ESP_FOC_DEBUG_CORE_TIMING
        default 22

    config ESP_FOC_OPEN_LOOP_ONLY
        bool "Enable open loop simulated observer on sensorless mode"
        default n

    config ESP_FOC_TUNER_ENABLE
        bool "Enable runtime PI tuner backend"
        default n
        help
            Compiles esp_foc_tuner.c (transport-agnostic request handler
            for live PI tuning). User code attaches axes via
            esp_foc_tuner_attach_axis() and calls
            esp_foc_tuner_handle_request() from a transport task.

    choice ESP_FOC_TUNER_BRIDGE
        prompt "Tuner transport bridge"
        depends on ESP_FOC_TUNER_ENABLE
        default ESP_FOC_BRIDGE_NONE
        help
            Selects the physical bus that ferries tuner / scope frames
            between the firmware and TunerStudio. Pick "None" if you
            implement the weak callbacks in your own application.

        config ESP_FOC_BRIDGE_NONE
            bool "None (user provides callbacks)"

        config ESP_FOC_BRIDGE_UART
            bool "UART"
            help
                Uses one of the chip's UART peripherals; works on every
                ESP32 variant including the original ESP32 without USB.

        config ESP_FOC_BRIDGE_USBCDC
            bool "USB CDC-ACM (TinyUSB)"
            depends on IDF_TARGET_ESP32S2 || IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4
            help
                Uses TinyUSB CDC-ACM. No external adapter required;
                the same cable used to flash the board carries the tuner
                traffic. Requires the espressif/tinyusb managed component.

    endchoice

    if ESP_FOC_BRIDGE_UART
        config ESP_FOC_BRIDGE_UART_NUM
            int "UART peripheral number"
            range 0 2
            default 1
        config ESP_FOC_BRIDGE_UART_BAUD
            int "UART baud rate"
            default 921600
        config ESP_FOC_BRIDGE_UART_TX_PIN
            int "UART TX pin"
            default 17
        config ESP_FOC_BRIDGE_UART_RX_PIN
            int "UART RX pin"
            default 18
    endif

    config ESP_FOC_INJECTION_ENABLE
        bool "Enable signal injection on the q-axis current reference"
        default n
        help
            Compiles the injection hook in the current-loop. When enabled
            the tuner (or any other caller) can arm step or chirp
            injections via esp_foc_axis_inject_*() to capture step or
            frequency responses through the scope.

    menu "Build-time PI autotuning"

        config ESP_FOC_USE_AUTOGEN_GAINS
            bool "Use build-time autotuned PI gains"
            default y
            help
                When enabled, esp_foc_initialize_axis() seeds every axis
                with Kp/Ki/integrator_limit produced by
                scripts/gen_pi_gains.py for the selected motor profile.
                When disabled, gains start at zero and must be programmed
                via the runtime tuner before the loop is commanded.

        config ESP_FOC_MOTOR_PROFILE
            string "Motor profile name (under scripts/motors/)"
            depends on ESP_FOC_USE_AUTOGEN_GAINS
            default "default"
            help
                Selects scripts/motors/<NAME>.json as input to the
                autotuner. Add new files in that directory to support
                more motors.

        config ESP_FOC_AUTOGEN_PWM_RATE_HZ
            int "PWM rate the autotuner assumes [Hz]"
            depends on ESP_FOC_USE_AUTOGEN_GAINS
            default 20000

        config ESP_FOC_AUTOGEN_DECIMATION
            int "Current loop decimation factor the autotuner assumes"
            depends on ESP_FOC_USE_AUTOGEN_GAINS
            default 20
            help
                Should match ESP_FOC_LOW_SPEED_DOWNSAMPLING in
                esp_foc_controls.h. Use 1 for ISR-mode control loops.

    endmenu

endmenu


