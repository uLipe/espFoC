/*
 * {app_name} — generated by espFoC TunerStudio.
 *
 * Hardware snapshot:
 *   target              : {target}
 *   inverter            : {pwm_type} @ {pwm_freq_hz} Hz, DC link {dc_link_v} V
 *   PWM pins (U,V,W)    : {pin_u_hi}/{pin_u_lo}, {pin_v_hi}/{pin_v_lo}, {pin_w_hi}/{pin_w_lo}
 *   rotor sensor        : {sensor_type}
 *   pole pairs          : {pole_pairs}
 *   motor profile       : {motor_profile}
 *
 * Tuned at generation time:
 *   Kp                  : {kp:.6f}
 *   Ki                  : {ki:.4f}
 *   integrator_limit    : {ilim:.4f}
 *   bandwidth target    : {bw_hz:.1f} Hz
 *   measured R / L      : {r_ohm:.4f} ohm / {l_h:.6f} H
 *   current LPF cutoff  : {current_filter_fc_hz:.1f} Hz (baked into the
 *                         NVS calibration shipped alongside this app)
 *
 * Edit application_tick() with your own control logic. The runtime
 * tuner stays attached so TunerStudio can still talk to the board
 * (helpful for re-tuning after mechanical changes).
 */

#include "esp_log.h"
#include "esp_err.h"
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"

#include "espFoC/esp_foc.h"
#include "espFoC/esp_foc_axis_tuning.h"
#include "espFoC/inverter_6pwm_mcpwm.h"
#include "espFoC/rotor_sensor_as5600.h"
#include "espFoC/utils/esp_foc_q16.h"

static const char *TAG = "{app_name}";

static esp_foc_axis_t s_axis;
static esp_foc_inverter_t *s_inverter;
static esp_foc_rotor_sensor_t *s_rotor;

static void parked_regulation_cb(esp_foc_axis_t *axis,
                                 esp_foc_d_current_q16_t *id_ref,
                                 esp_foc_q_current_q16_t *iq_ref,
                                 esp_foc_d_voltage_q16_t *ud_ff,
                                 esp_foc_q_voltage_q16_t *uq_ff)
{{
    (void)axis;
    id_ref->raw = 0;
    iq_ref->raw = 0;
    ud_ff->raw = 0;
    uq_ff->raw = 0;
}}

void app_main(void)
{{
    ESP_LOGI(TAG, "boot — {app_name}");

    s_inverter = inverter_6pwm_mpcwm_new(
        {pin_u_hi}, {pin_u_lo},
        {pin_v_hi}, {pin_v_lo},
        {pin_w_hi}, {pin_w_lo},
        {inverter_en_gpio}, {dc_link_v}f, 0);
    if (s_inverter == NULL) {{
        ESP_LOGE(TAG, "inverter init failed");
        return;
    }}

    s_rotor = rotor_sensor_as5600_new({sda}, {scl}, 0);
    if (s_rotor == NULL) {{
        ESP_LOGE(TAG, "rotor sensor init failed");
        return;
    }}

    esp_foc_motor_control_settings_t settings = {{
        .motor_pole_pairs  = {pole_pairs},
        .natural_direction = ESP_FOC_MOTOR_NATURAL_DIRECTION_CW,
        .motor_unit        = 0,
    }};

    ESP_ERROR_CHECK(esp_foc_initialize_axis(&s_axis, s_inverter,
                                            s_rotor, NULL, settings));

    /* Override the autogen seed with the gains TunerStudio captured at
     * generation time. The NVS overlay (if present) will still win on
     * next boot — this just guarantees a sane starting point on first
     * flash even when NVS is empty. */
    ESP_ERROR_CHECK(esp_foc_axis_set_current_pi_gains_q16(
        &s_axis, {kp_q16}, {ki_q16}, {ilim_q16}));

    esp_foc_set_regulation_callback(&s_axis, parked_regulation_cb);

    ESP_ERROR_CHECK(esp_foc_align_axis(&s_axis));
    ESP_ERROR_CHECK(esp_foc_run(&s_axis));

    ESP_LOGI(TAG, "axis running — replace parked_regulation_cb with your logic");
    while (1) {{
        vTaskDelay(pdMS_TO_TICKS(1000));
    }}
}}
