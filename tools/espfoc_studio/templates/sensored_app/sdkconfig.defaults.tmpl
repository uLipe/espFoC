# Generated by espFoC TunerStudio for {app_name}
# Target: {target}
# Profile: {motor_profile} (hash 0x{profile_hash:08x})

CONFIG_ESP_TASK_WDT_EN=n


# Tuner stays compiled in so the operator can re-tune live without
# rebuilding firmware. Calibration overlay reads the persisted NVS
# blob (if present) at boot and lets it rule over the autogen header.
CONFIG_ESP_FOC_TUNER_ENABLE=y
CONFIG_ESP_FOC_CALIBRATION_NVS=y
CONFIG_ESP_FOC_USE_AUTOGEN_GAINS=y
CONFIG_ESP_FOC_MOTOR_PROFILE="{motor_profile}"
CONFIG_ESP_FOC_AUTOGEN_PWM_RATE_HZ={pwm_freq_hz}
CONFIG_ESP_FOC_AUTOGEN_DECIMATION=20
