/build/
/.vscode/
*.o
*.lock
/dist/
examples/test_project/
/.cache/
/examples/*/build/
/examples/*/sdkconfig.old
/examples/*/*.lock
examples/unit_test_runner/__pycache__/

# QEMU flash/efuse blobs generated by unit test harness
**/qemu_flash.bin
**/qemu_efuse.bin

# Build-time autotuned PI gains. Primary location is build/, but these
# defensive globs catch any accidental in-tree generation.
**/esp_foc_autotuned_gains.h
**/esp_foc_autotuned_report.txt
scripts/motors/*.generated.json
scripts/__pycache__/
**/__pycache__/
.cursor/
