# axis_shell — scope stream (USJ) + console shell; no tuner/link.

CONFIG_ESP_TASK_WDT_EN=n

CONFIG_ESP_FOC_SCOPE=y
CONFIG_ESP_FOC_SCOPE_NUM_CHANNELS=17
CONFIG_ESP_FOC_SCOPE_BUFFER_SIZE=8
CONFIG_ESP_FOC_SCOPE_DAEMON_PRIORITY=3

CONFIG_ESP_FOC_CALIBRATION_NVS=y
CONFIG_ESPFOC_SHELL=y
CONFIG_ESP_FOC_PWM_RATE_HZ=20000

# QBL4208-61-04-013 (wye: R/L from line-line ÷ 2, 24 V bus, 10.6 A peak limit)
CONFIG_ESP_FOC_DC_LINK_NOMINAL_MV=24000
CONFIG_AXIS_TUNING_DC_LINK_V=24
CONFIG_FOC_ITL_DEFAULT_R_MILLIOHM=360
CONFIG_FOC_ITL_DEFAULT_L_UH=600
CONFIG_FOC_ITL_DEFAULT_J_X1E7=480
CONFIG_FOC_ITL_DEFAULT_KT_X1E7=360000
CONFIG_FOC_ITL_DEFAULT_POLE_PAIRS=4
CONFIG_FOC_ITL_DEFAULT_I_MAX_MA=10600

CONFIG_AXIS_SHELL_PLANT_FITL=y
CONFIG_ESP_FOC_FITL=y
CONFIG_FOC_ITL_TICK_MCPWM=y

CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_ADC_CONTINUOUS_ISR_IRAM_SAFE=y

CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
