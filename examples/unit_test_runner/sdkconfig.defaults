# Disable task watchdog so unity_run_menu() (waiting for serial input) does not trigger it
CONFIG_ESP_TASK_WDT_EN=n

# Enable NVS calibration overlay for unit tests
CONFIG_ESP_FOC_CALIBRATION_NVS=y

# FOC-in-the-loop plant + GPTimer tick for QEMU CI (MCPWM timers do not run in QEMU)
CONFIG_ESP_FOC_FITL=y
# CONFIG_FOC_ITL_TICK_MCPWM is not set
CONFIG_FOC_ITL_TICK_GPTIMER=y
