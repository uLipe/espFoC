menu "TunerStudio target — pin map"

    config TUNER_TARGET_PWM_U_HI
        int "PWM U high pin"
        range 0 54
        default 5

    config TUNER_TARGET_PWM_V_HI
        int "PWM V high pin"
        range 0 54
        default 6

    config TUNER_TARGET_PWM_W_HI
        int "PWM W high pin"
        range 0 54
        default 7

    config TUNER_TARGET_PWM_U_LO
        int "PWM U low pin"
        range 0 54
        default 15

    config TUNER_TARGET_PWM_V_LO
        int "PWM V low pin"
        range 0 54
        default 16

    config TUNER_TARGET_PWM_W_LO
        int "PWM W low pin"
        range 0 54
        default 17

    config TUNER_TARGET_PWM_FREQ_HZ
        int "PWM frequency [Hz]"
        default 20000

    config TUNER_TARGET_DC_LINK_V
        int "DC link voltage (Volts)"
        default 12

    config TUNER_TARGET_ENC_SDA
        int "Encoder I2C SDA pin"
        range 0 54
        default 4

    config TUNER_TARGET_ENC_SCL
        int "Encoder I2C SCL pin"
        range 0 54
        default 8

    config TUNER_TARGET_POLE_PAIRS
        int "Motor pole pairs"
        range 1 64
        default 7

    comment "ADC shunt current sensing"

    config TUNER_TARGET_ISENSE_ADC_UNIT
        int "ADC unit (1 or 2)"
        range 1 2
        default 1

    config TUNER_TARGET_ISENSE_CH_U
        int "ADC channel for phase U shunt"
        range 0 9
        default 1

    config TUNER_TARGET_ISENSE_CH_V
        int "ADC channel for phase V shunt"
        range 0 9
        default 5

    config TUNER_TARGET_ISENSE_AMP_GAIN_X100
        int "Current amplifier gain (V/V) x100"
        range 1 100000
        default 5000
        help
            Stored x100 because Kconfig int does not accept floats.
            Default 5000 -> 50.0 V/V (typical INA240A2).

    config TUNER_TARGET_ISENSE_SHUNT_MOHM
        int "Shunt resistance (milli-ohm)"
        range 1 10000
        default 10
        help
            10 mOhm matches the SimpleFOCShield-style boards.

endmenu
