# axis_tuning — reference firmware with runtime tuner always enabled.
# Host drives align → run → tune → store → stop via tunerctl / Studio.

CONFIG_ESP_TASK_WDT_EN=n

CONFIG_ESP_FOC_TUNER_ENABLE=y
CONFIG_ESP_FOC_BRIDGE_NONE=n

CONFIG_ESP_FOC_SCOPE=y
CONFIG_ESP_FOC_SCOPE_NUM_CHANNELS=13
CONFIG_ESP_FOC_SCOPE_BUFFER_SIZE=512

CONFIG_ESP_FOC_CALIBRATION_NVS=y
CONFIG_ESP_FOC_PWM_RATE_HZ=20000

CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_ADC_CONTINUOUS_ISR_IRAM_SAFE=y
